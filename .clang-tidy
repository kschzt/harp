# clang-tidy for HARP (C) — a static-analysis tier over the wire-facing + RT code,
# on top of the compiler's own -Wall -Wextra -Werror (HARP_WERROR) and cppcheck.
#
# The tree is CLEAN under this set: clang-analyzer-* (the real path-sensitive analyzer —
# null derefs, leaks, uninit reads, logic) reports nothing, and the curated bugprone/cert
# checks pass. Noisy/opinionated checks that flag STYLE rather than defects on this
# codebase are disabled WITH RATIONALE so the gate stays meaningful, not a rubber stamp:
#   easily-swappable-parameters      — flags any 2+ same-type params; endemic in C, not a bug
#   narrowing-conversions            — DSP int<->float math is intentional and range-safe
#   implicit-widening-of-mult-result — small-count block/index math; no overflow reachable
#   switch-missing-default-case      — several switches are exhaustive over a validated domain
#   branch-clone                     — a few switches keep identical arms for readability
#   concurrency-mt-unsafe (not enabled) — assessed: the only hits are getenv() test-seams at
#     single-threaded init + a clean exit() at shutdown; no RT-thread hazard, so gating it
#     would only add NOLINT churn. Re-enable if a real MT-unsafe call lands in a worker thread.
Checks: >
  -*,
  clang-analyzer-*,
  bugprone-*,
  cert-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-switch-missing-default-case,
  -bugprone-branch-clone,
  -cert-dcl16-c,
  -cert-err33-c
WarningsAsErrors: '*'
HeaderFilterRegex: '(core|device|host)/.*\.h$'
