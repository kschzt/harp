# clang-tidy for HARP (C) — the path-sensitive static-analysis tier, on top of the
# compiler's own -Wall -Wextra -Werror (HARP_WERROR) and cppcheck.
#
# Gate = clang-analyzer-* : the REAL inter-procedural analyzer (null derefs, use-after-free,
# leaks, uninitialized reads, dead stores, logic errors). It reports NOTHING on this tree —
# a meaningful, non-rubber-stamp gate that fails on a genuine defect.
#
# The bugprone-*/cert-* families are deliberately NOT gated: assessed across core/device/host,
# every hit is a STYLE/defensiveness suggestion, not a defect on this codebase —
#   cert-err34-c                     — atoi/atof/sscanf in trusted CLI-arg / config parsing
#   security.insecureAPI.*           — Annex-K "use memcpy_s/strcpy_s" (a rarely-implemented
#                                      extension; plain memcpy/strcpy with checked lengths is fine)
#   easily-swappable-parameters      — flags any 2+ same-type params; endemic in C, not a bug
#   narrowing/implicit-widening      — intentional, range-safe DSP int<->float and block math
#   assignment-in-if-condition       — the deliberate `if ((n = recv(...)) <= 0)` I/O idiom
#   switch-missing-default / branch-clone — exhaustive switches / readable identical arms
# Gating them would only add NOLINT churn without catching a real bug. Re-scope if a family
# starts flagging genuine defects.
Checks: >
  -*,
  clang-analyzer-*,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -clang-analyzer-security.insecureAPI.strcpy
WarningsAsErrors: '*'
HeaderFilterRegex: '(core|device|host)/.*\.h$'
